# ========================================
# AI Sales Agent Platform - Environment Variables
# ========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Next.js-compatible names if you prefer frontend-style env vars
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# --- Twilio (optional - for voice/SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Pinecone (for vector search / RAG) ---
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=agents
PINECONE_ENVIRONMENT=us-east-1

# --- ElevenLabs (optional - for TTS) ---
ELEVENLABS_API_KEY=your-key

# --- SendGrid (optional - for email) ---
SENDGRID_API_KEY=your-key

# --- HubSpot (optional - for CRM) ---
HUBSPOT_API_KEY=your-key

# --- Google Calendar (optional) ---
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials.json

# --- App Config ---
SECRET_KEY=your-secret-key-for-jwt
ENCRYPTION_KEY=your-aes-256-key-for-api-key-encryption
